:global AddressList
:global ForwardTo
/ip dns static
:if ([:len [find name="97ting.com"]] = 0) do={ add address-list=$AddressList forward-to=$ForwardTo comment="tencent-tme" match-subdomain=yes type=FWD name="97ting.com" }
